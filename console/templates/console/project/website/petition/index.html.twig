{% extends 'console/project/base.html.twig' %}

{% block page_title 'index.title'|trans({}, 'project_petitions') %}

{% block sidebar_petitions 'current' %}

{% from 'console/_macros/pagination.html.twig' import pagination %}

{% block content %}
    <div class="world-box mb-3">
        <div class="world-box-title">
            <div class="row align-items-center">
                <div class="col-lg-8 mb-3 mb-lg-0">
                    <h3>
                        {{ 'index.title'|trans({}, 'project_petitions') }}
                    </h3>

                    <div class="text-muted">
                        {{ 'index.help'|trans({}, 'project_petitions') }}
                    </div>
                </div>
                <div class="col-lg-4 text-lg-right">
                    <a href="{{ path('console_website_petitions_categories', { 'projectUuid': project.uuid }) }}"
                       class="btn btn-secondary mr-2 posts-list-action-categories">
                        <i class="fad fa-cogs mr-1"></i>
                        {{ 'index.edit_categories'|trans({}, 'project_petitions') }}
                    </a>

                    <a href="{{ csrf_path('console_website_post_create', { 'projectUuid': project.uuid }) }}"
                       class="btn btn-primary posts-list-action-create">
                        <i class="far fa-plus mr-1"></i>
                        {{ 'index.create'|trans({}, 'project_petitions') }}
                    </a>
                </div>
            </div>
        </div>

        <div class="bg-light">
            dono what comes here
        </div>
    </div>
{% endblock %}
